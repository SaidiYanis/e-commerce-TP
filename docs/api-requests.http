@baseUrl = http://localhost:5214

### Create category
# @name createCategory
POST {{baseUrl}}/categories
Content-Type: application/json

{
  "title": "Tech",
  "description": "Technology products",
  "color": "blue"
}

### Create product
# @name createProduct
POST {{baseUrl}}/products
Content-Type: application/json

{
  "title": "Laptop",
  "description": "A powerful laptop",
  "price": 1200,
  "promotionalPrice": 999,
  "stock": 5,
  "categoryId": "{{createCategory.response.body.$.id}}"
}

### Create order
# @name createOrder
POST {{baseUrl}}/orders
Content-Type: application/json

{
  "productId": "{{createProduct.response.body.$.id}}"
}

### Add one line to existing order
# @name addOrderLine
POST {{baseUrl}}/orders/{{createOrder.response.body.$.id}}/lines
Content-Type: application/json

{
  "productId": "{{createProduct.response.body.$.id}}"
}

### Pay order
# @name payOrder
POST {{baseUrl}}/orders/{{createOrder.response.body.$.id}}/pay

### Deliver order
# @name deliverOrder
POST {{baseUrl}}/orders/{{createOrder.response.body.$.id}}/deliver

### Business error example: invalid product because promotional price equals price
# @name createInvalidProduct
POST {{baseUrl}}/products
Content-Type: application/json

{
  "title": "Invalid laptop",
  "description": "This request should fail",
  "price": 1000,
  "promotionalPrice": 1000,
  "stock": 3,
  "categoryId": "{{createCategory.response.body.$.id}}"
}
